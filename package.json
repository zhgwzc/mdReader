{
  "name": "md-reader",
  "version": "1.0.0",
  "description": "A WYSIWYG Markdown editor built with Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-markdown": "^6.3.3",
    "@codemirror/language": "^6.11.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.6",
    "@lezer/highlight": "^1.2.1",
    "codemirror": "^6.0.1",
    "iconv-lite": "^0.7.2",
    "jschardet": "^3.1.4",
    "markdown-it": "^14.1.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "electron": "^35.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.mdreader.editor",
    "productName": "MD阅读器",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "icon": "build/icon.png",
      "target": "dmg"
    },
    "win": {
      "icon": "build/icon.png",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MD阅读器"
    }
  }
}
